# Comma-separated wallet addresses that should receive fake localhost gas during bootstrap.
SETTLEMENT_BOOTSTRAP_WALLETS=0xYOUR_DEV_WALLET_1,0xYOUR_DEV_WALLET_2
# Amount of fake localhost native currency to send to each bootstrap wallet
SETTLEMENT_BOOTSTRAP_NATIVE_AMOUNT=25

# Private key used for public-network deployments like Amoy or Polygon.
# Leave this blank if you are only using localhost.
DEPLOYER_PRIVATE_KEY=
# Optional RPC URL for Polygon Amoy. Fill this in only when you want `deploy:amoy` to work.
AMOY_RPC_URL=
# Optional RPC URL for Polygon mainnet. Fill this in only when you want `deploy:polygon` to work.
POLYGON_RPC_URL=
