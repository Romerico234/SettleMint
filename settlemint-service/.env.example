# Runtime environment for the API
APP_ENV=development
# Port the backend API listens on
PORT=8080
# MongoDB connection string; use settlemint-mongo inside Docker Compose
MONGODB_URI=mongodb://settlemint-mongo:27017
# MongoDB database name for this environment
MONGODB_DATABASE=settlemint_db_dev
# Secret used to sign wallet-auth API tokens
AUTH_TOKEN_SECRET=settlemint-dev-secret-change-me
# Frontend origin allowed to call the backend API
CORS_ALLOWED_ORIGIN=http://localhost:5173
# IPFS_API_URL is the Kubo API endpoint the backend uses to add and read archived JSON by CID.
# When the backend runs in Docker Compose, point this at the Kubo service name and API port.
IPFS_API_URL=http://settlemint-ipfs:5001
# IPFS_GATEWAY_URL is the browser-facing gateway base URL persisted with each archive record.
# Keep this on a host port that does not conflict with the backend; Compose maps the Kubo gateway to localhost:8081.
IPFS_GATEWAY_URL=http://localhost:8081

# Active blockchain profile key from settlemint-chain/networks.ts
SETTLEMENT_NETWORK=localhost
# RPC URL the backend uses to verify submitted wallet transfers
# Use http://127.0.0.1:8545 when running the backend outside Docker
SETTLEMENT_RPC_URL=http://host.docker.internal:8545
# Chain ID expected for settlement payment verification
SETTLEMENT_CHAIN_ID=31337
# Deployed SettlementProof contract address for the active blockchain profile
SETTLEMENT_PROOF_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
